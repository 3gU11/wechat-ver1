<view class="page">
  <view class="brand-strip">
    <image class="brand-logo" src="/images/rj-logo.png" mode="aspectFit" />
    <view>
      <view class="brand-name">经销商门户</view>
      <view class="brand-subtitle">账号管理</view>
    </view>
  </view>
  <view class="head-row">
    <view>
      <view class="section-title">账号注册审核</view>
      <view class="desc">审核普通经销商和大区经理账号，也可以删除账号或修改登录密码。</view>
    </view>
    <button class="logout-btn" bindtap="logout">退出</button>
  </view>

  <view class="review-list">
    <view class="card review-card" wx:for="{{applications}}" wx:key="id">
      <view class="top">
        <view>
          <view class="company">{{item.companyName}}</view>
          <view class="meta">{{item.contactName}} · {{item.phone}}</view>
          <view class="meta">账号类型：{{item.role === 'regional_manager' ? '大区经理' : '普通经销商'}}</view>
          <view wx:if="{{item.regionalManagerName}}" class="meta">所属大区经理：{{item.regionalManagerName}}</view>
          <view class="meta">所在地区：{{item.region || '-'}}</view>
        </view>
        <view class="tag {{item.status === 'pending' ? 'warn' : item.status === 'rejected' ? 'gray' : ''}}">
          {{item.status === 'approved' ? '已通过' : item.status === 'rejected' ? '已拒绝' : '待审核'}}
        </view>
      </view>
      <view class="time">申请时间：{{item.createdAt}}</view>

      <view class="actions">
        <button wx:if="{{item.status === 'pending'}}" class="reject-btn" data-id="{{item.id}}" data-status="rejected" bindtap="review">拒绝</button>
        <button wx:if="{{item.status === 'pending'}}" class="approve-btn" data-id="{{item.id}}" data-status="approved" bindtap="review">通过</button>
        <button class="password-btn" data-id="{{item.id}}" bindtap="changePassword">改密码</button>
        <button class="delete-btn" data-id="{{item.id}}" data-name="{{item.companyName}}" bindtap="deleteAccount">删除</button>
      </view>
    </view>
  </view>
</view>
