.head-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.mini-btn {
  width: 138rpx;
  height: 66rpx;
  line-height: normal;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  background: #1f4f9a;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
}

.order-list {
  display: flex;
  flex-direction: column;
}

.order-card {
  padding: 24rpx;
}

.order-top {
  display: flex;
  justify-content: space-between;
}

.order-id {
  font-size: 30rpx;
  font-weight: 700;
  color: #14366f;
}

.customer {
  margin-top: 18rpx;
  font-size: 28rpx;
  color: #172033;
}

.meta,
.time {
  margin-top: 10rpx;
  color: #66758f;
  font-size: 25rpx;
}

.empty {
  padding: 80rpx 0;
  text-align: center;
  font-size: 26rpx;
}

.line-item {
  margin-top: 10rpx;
  padding: 12rpx 14rpx;
  border-radius: 12rpx;
  background: #f7faff;
  color: #334155;
  font-size: 25rpx;
  line-height: 1.5;
}

.review-note {
  margin-top: 10rpx;
  padding: 12rpx 14rpx;
  border-radius: 8rpx;
  background: #fef3c7;
  color: #92400e;
  font-size: 24rpx;
  line-height: 1.5;
}

.actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 20rpx;
}

.approve-btn,
.reject-btn {
  width: 160rpx;
  height: 60rpx;
  line-height: normal;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 700;
}

.allocate-btn {
  width: 180rpx;
}

.approve-btn {
  background: #1f4f9a;
}

.reject-btn {
  background: #b42318;
}

