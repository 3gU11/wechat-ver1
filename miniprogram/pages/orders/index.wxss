.head-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.mini-btn {
  width: 120rpx;
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 8rpx;
  background: #0f766e;
  color: #ffffff;
  font-size: 25rpx;
}

.order-list {
  display: flex;
  flex-direction: column;
}

.order-card {
  padding: 24rpx;
}

.order-top {
  display: flex;
  justify-content: space-between;
}

.order-id {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
}

.customer {
  margin-top: 18rpx;
  font-size: 28rpx;
  color: #344054;
}

.meta,
.time {
  margin-top: 10rpx;
  color: #667085;
  font-size: 25rpx;
}

.empty {
  padding: 80rpx 0;
  text-align: center;
  font-size: 26rpx;
}

.line-item {
  margin-top: 10rpx;
  padding: 12rpx 14rpx;
  border-radius: 8rpx;
  background: #f8fafc;
  color: #344054;
  font-size: 24rpx;
  line-height: 1.5;
}

