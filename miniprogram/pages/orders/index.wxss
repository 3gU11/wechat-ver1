.head-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.mini-btn {
  width: 138rpx;
  height: 66rpx;
  line-height: normal;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  background: #1f4f9a;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
}

.order-list {
  display: flex;
  flex-direction: column;
}

.filter-panel {
  margin: 18rpx 0;
  padding: 18rpx;
  border: 1rpx solid #d8e4f5;
  border-radius: 12rpx;
  background: #ffffff;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 64rpx;
  padding: 0 18rpx;
  border: 1rpx solid #d8e4f5;
  border-radius: 8rpx;
  font-size: 25rpx;
  box-sizing: border-box;
}

.clear-search {
  width: 92rpx;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0;
  border-radius: 8rpx;
  background: #eef4ff;
  color: #1f4f9a;
  font-size: 24rpx;
}

.status-filter,
.refresh-time {
  margin-top: 12rpx;
  color: #66758f;
  font-size: 24rpx;
}

.order-card {
  padding: 24rpx;
}

.order-top {
  display: flex;
  justify-content: space-between;
}

.order-id {
  font-size: 30rpx;
  font-weight: 700;
  color: #14366f;
}

.customer {
  margin-top: 18rpx;
  font-size: 28rpx;
  color: #172033;
}

.meta,
.time {
  margin-top: 10rpx;
  color: #66758f;
  font-size: 25rpx;
}

.empty {
  padding: 80rpx 0;
  text-align: center;
  font-size: 26rpx;
}

.line-item {
  margin-top: 10rpx;
  padding: 12rpx 14rpx;
  border-radius: 12rpx;
  background: #f7faff;
  color: #334155;
  font-size: 25rpx;
  line-height: 1.5;
}

.extra-row {
  margin-top: 10rpx;
  min-height: 58rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.extra-tip,
.pending-label {
  margin-top: 8rpx;
  color: #92400e;
  font-size: 23rpx;
}

.extra-label {
  flex: 0 0 auto;
  color: #66758f;
  font-size: 24rpx;
}

.extra-input {
  min-width: 0;
  flex: 1;
  height: 52rpx;
  line-height: 52rpx;
  padding: 0 12rpx;
  border: 1rpx solid #d8e4f5;
  border-radius: 8rpx;
  background: #ffffff;
  font-size: 24rpx;
  box-sizing: border-box;
}

.extra-text {
  min-width: 0;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 24rpx;
  color: #334155;
}

.extra-qty {
  flex: 0 0 auto;
  font-size: 24rpx;
  color: #66758f;
}

.qty-stepper {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  height: 52rpx;
  border: 1rpx solid #d8e4f5;
  border-radius: 8rpx;
  overflow: hidden;
  background: #ffffff;
}

.qty-stepper button {
  width: 48rpx;
  height: 52rpx;
  line-height: 52rpx;
  padding: 0;
  border-radius: 0;
  background: #eef4ff;
  color: #1f4f9a;
  font-size: 26rpx;
}

.qty-stepper input {
  width: 58rpx;
  height: 52rpx;
  min-height: 52rpx;
  text-align: center;
  font-size: 24rpx;
}

.review-note {
  margin-top: 10rpx;
  padding: 12rpx 14rpx;
  border-radius: 8rpx;
  background: #fef3c7;
  color: #92400e;
  font-size: 24rpx;
  line-height: 1.5;
}

.actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 20rpx;
}

.remark-actions {
  display: flex;
  justify-content: flex-end;
  gap: 14rpx;
  margin-top: 18rpx;
}

.remark-save-btn,
.detail-btn {
  width: 190rpx;
  height: 60rpx;
  line-height: normal;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  background: #1f4f9a;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
}

.detail-btn {
  background: #eef4ff;
  color: #1f4f9a;
}

.approve-btn,
.reject-btn {
  width: 160rpx;
  height: 60rpx;
  line-height: normal;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 700;
}

.allocate-btn {
  width: 180rpx;
}

.approve-btn {
  background: #1f4f9a;
}

.reject-btn {
  background: #b42318;
}

