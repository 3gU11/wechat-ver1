.profile-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 34rpx 28rpx;
  margin-bottom: 30rpx;
  text-align: center;
}

.brand-strip {
  justify-content: center;
  text-align: center;
}

.brand-strip .brand-logo {
  width: 230rpx;
  height: 78rpx;
}

.avatar {
  width: 108rpx;
  height: 108rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  background: #1f4f9a;
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 700;
}

.account-info {
  width: 100%;
  margin-top: 18rpx;
  text-align: center;
}

.name {
  font-size: 34rpx;
  font-weight: 700;
  color: #14366f;
  text-align: center;
  word-break: break-all;
}

.contact {
  margin-top: 8rpx;
  color: #66758f;
  font-size: 25rpx;
  text-align: center;
}

.action-btn {
  width: 100%;
  margin-bottom: 18rpx;
}

.rule-card,
.api-card {
  padding: 8rpx 24rpx;
}

.rule,
.api-line {
  padding: 20rpx 0;
  border-top: 1rpx solid #e4ecf8;
  font-size: 26rpx;
  color: #334155;
}

.rule:first-child, .api-line:first-child {
  border-top: 0;
}

.api-line {
  font-family: Consolas, "Courier New", monospace;
  color: #1f4f9a;
}

