<view class="page">
  <view class="brand-strip">
    <image class="brand-logo" src="/images/rj-logo.png" mode="aspectFit" />
    <view>
      <view class="brand-name">经销商门户</view>
      <view class="brand-subtitle">我的账号</view>
    </view>
  </view>

  <view wx:if="{{!account}}" class="card rule-card">
    <view class="rule">请先在首页登录账号</view>
  </view>

  <view wx:else class="card profile-card">
    <view class="avatar" style="width: 89rpx; height: 85rpx; display: block; box-sizing: border-box">{{avatarText}}</view>
    <view>
      <view class="name" style="width: 193rpx; display: block; box-sizing: border-box; left: 0rpx; top: 0rpx">{{account.name || '经销商账号'}}</view>
      <view class="contact">{{account.phone}} · {{account.role === 'admin' ? '管理员' : account.role === 'regional_manager' ? '大区经理' : '普通经销商'}}</view>
      <view wx:if="{{account.region}}" class="contact">所在地区：{{account.region}}</view>
    </view>
  </view>

  <button wx:if="{{account.role === 'admin'}}" class="primary-btn action-btn" bindtap="goAdminReviews">进入经销商审核</button>
  <button class="secondary-btn action-btn" bindtap="logout">退出登录</button>
</view>
