.filter {
  padding: 18rpx;
  margin-bottom: 20rpx;
}

.search-row {
  display: flex;
}

.search-input {
  flex: 1;
  height: 72rpx;
  box-sizing: border-box;
  padding: 0 20rpx;
  border: 1rpx solid #d0d5dd;
  border-radius: 8rpx;
  background: #ffffff;
  font-size: 26rpx;
}

.search-btn {
  width: 144rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 8rpx;
  background: #eef6f5;
  color: #0f766e;
  font-size: 26rpx;
}

.model-list {
  display: flex;
  flex-direction: column;
}

.model-card {
  padding: 24rpx;
}

.model-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.model {
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
}

.serial {
  margin-top: 8rpx;
  color: #667085;
  font-size: 24rpx;
}

.qty {
  min-width: 108rpx;
  text-align: right;
  font-size: 46rpx;
  font-weight: 700;
  color: #0f766e;
}

.bind-btn {
  width: 100%;
  margin-top: 24rpx;
}

.empty {
  padding: 80rpx 0;
  text-align: center;
  font-size: 26rpx;
}

