.filter {
  padding: 18rpx;
  margin-bottom: 20rpx;
}

.search-row {
  display: flex;
}

.search-input {
  flex: 1;
  height: 78rpx;
  box-sizing: border-box;
  padding: 0 20rpx;
  border: 1rpx solid #d8e4f5;
  border-radius: 12rpx;
  background: #ffffff;
  font-size: 28rpx;
}

.search-btn {
  width: 150rpx;
  height: 78rpx;
  line-height: normal;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  background: #fff3df;
  color: #b55c00;
  font-size: 28rpx;
  font-weight: 700;
}

.model-list {
  display: flex;
  flex-direction: column;
}

.model-card {
  padding: 28rpx;
}

.model-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.model {
  font-size: 36rpx;
  font-weight: 700;
  color: #14366f;
}

.serial {
  margin-top: 8rpx;
  color: #66758f;
  font-size: 26rpx;
}

.bind-btn {
  width: 100%;
  margin-top: 24rpx;
}

.empty {
  padding: 80rpx 0;
  text-align: center;
  font-size: 26rpx;
}

.floating-cart {
  position: fixed;
  right: 28rpx;
  bottom: 48rpx;
  z-index: 20;
  width: 140rpx;
  height: 112rpx;
  padding: 14rpx 0;
  border-radius: 14rpx;
  background: #1f4f9a;
  color: #ffffff;
  font-size: 24rpx;
  line-height: 1.2;
  box-shadow: 0 12rpx 28rpx rgba(31, 79, 154, 0.26);
}

.cart-count {
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.quantity-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 30;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(17, 24, 39, 0.36);
}

.quantity-dialog {
  width: 640rpx;
  box-sizing: border-box;
  padding: 32rpx;
  border-radius: 14rpx;
  background: #ffffff;
}

.quantity-title {
  color: #14366f;
  font-size: 32rpx;
  font-weight: 700;
}

.quantity-model {
  margin-top: 12rpx;
  color: #172033;
  font-size: 28rpx;
}

.quantity-desc,
.quantity-current {
  margin-top: 12rpx;
  color: #66758f;
  font-size: 24rpx;
}

.quantity-current {
  text-align: center;
}

.quantity-stepper {
  width: 340rpx;
  margin: 32rpx auto 0;
  display: flex;
  align-items: center;
  border: 1rpx solid #d8e4f5;
  border-radius: 12rpx;
  overflow: hidden;
}

.quantity-step {
  width: 76rpx;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0;
  border-radius: 0;
  background: #eaf2ff;
  color: #1f4f9a;
  font-size: 32rpx;
  font-weight: 700;
}

.quantity-input {
  flex: 1;
  min-width: 160rpx;
  height: 64rpx;
  box-sizing: border-box;
  padding: 0 12rpx;
  text-align: center;
  font-size: 28rpx;
  background: #ffffff;
  color: #172033;
}

.quantity-actions {
  margin-top: 32rpx;
  display: flex;
  gap: 12rpx;
}

.quantity-actions button {
  flex: 1;
  height: 68rpx;
  line-height: 68rpx;
  padding: 0;
  border-radius: 12rpx;
  font-size: 25rpx;
  font-weight: 700;
}

.quantity-cancel {
  background: #f1f5fb;
  color: #526173;
}

.quantity-cart {
  background: #fff3df;
  color: #b55c00;
}

.quantity-confirm {
  background: #1f4f9a;
  color: #ffffff;
}

