.summary-card,
.line-card,
.note-card {
  padding: 24rpx;
}

.order-id {
  color: #14366f;
  font-size: 32rpx;
  font-weight: 700;
}

.summary-row,
.summary-note,
.assigned,
.batch-meta {
  margin-top: 10rpx;
  color: #66758f;
  font-size: 26rpx;
  line-height: 1.5;
}

.summary-note {
  padding: 12rpx 14rpx;
  border-radius: 8rpx;
  background: #f7faff;
}

.line-list {
  display: flex;
  flex-direction: column;
}

.line-head,
.batch-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.line-side {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.fold {
  color: #f59e0b;
  font-size: 25rpx;
  font-weight: 700;
}

.model {
  color: #14366f;
  font-size: 34rpx;
  font-weight: 700;
}

.line-status,
.recommend {
  flex-shrink: 0;
  min-width: 112rpx;
  height: 48rpx;
  line-height: 48rpx;
  border-radius: 999rpx;
  background: #fff3df;
  color: #b55c00;
  text-align: center;
  font-size: 23rpx;
}

.line-status.done,
.recommend.yes {
  background: #eaf2ff;
  color: #1f4f9a;
}

.line-status.partial {
  background: #fef3c7;
  color: #92400e;
}

.recommend.no {
  background: #f1f5fb;
  color: #66758f;
}

.batch-list {
  margin-top: 18rpx;
  border-top: 1rpx solid #e4ecf8;
}

.batch-row {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #e4ecf8;
}

.batch-row.selected {
  background: #f7faff;
}

.batch-no {
  color: #14366f;
  font-size: 30rpx;
  font-weight: 700;
}

.qty-row {
  width: 240rpx;
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid #d8e4f5;
  border-radius: 12rpx;
  overflow: hidden;
}

.qty-row button {
  width: 64rpx;
  height: 58rpx;
  line-height: 58rpx;
  padding: 0;
  border-radius: 0;
  background: #ffffff;
  color: #1f4f9a;
  font-weight: 700;
}

.qty-row input {
  flex: 1;
  height: 58rpx;
  text-align: center;
  font-size: 26rpx;
}

.empty-batches {
  padding: 32rpx 0;
  color: #98a2b3;
  text-align: center;
  font-size: 25rpx;
}

.label {
  margin-bottom: 12rpx;
  color: #1f4f9a;
  font-size: 26rpx;
  font-weight: 700;
}

textarea {
  width: 100%;
  min-height: 140rpx;
  font-size: 28rpx;
}

.submit-btn {
  width: 100%;
  margin-top: 28rpx;
}

.submit-hint {
  margin-top: 18rpx;
  color: #92400e;
  font-size: 24rpx;
  line-height: 1.5;
  text-align: center;
}
