<view class="page">
  <view wx:if="{{order}}" class="card summary-card">
    <view class="order-id">{{order.id}}</view>
    <view class="summary-row">经销商：{{order.dealerName || '-'}}</view>
    <view class="summary-row">客户：{{order.customerName || '-'}}</view>
    <view class="summary-row">联系人：{{order.contactName || '-'}} · {{order.contactPhone || '-'}}</view>
    <view class="summary-row">期望交期：{{order.deliveryDate || '-'}}</view>
    <view wx:if="{{order.remark}}" class="summary-note">备注：{{order.remark}}</view>
  </view>

  <view class="line-list">
    <view class="card line-card" wx:for="{{lines}}" wx:for-item="line" wx:for-index="lineIndex" wx:key="lineNo">
      <view class="line-head">
        <view>
          <view class="model">{{line.model}}</view>
          <view class="assigned">已分配 {{line.assigned}} / {{line.demand}} 台，剩余 {{line.remaining}} 台</view>
        </view>
        <view class="line-status {{line.assigned === line.demand ? 'done' : line.assigned > 0 ? 'partial' : ''}}">
          {{line.assigned === line.demand ? '已满足' : line.assigned > 0 ? '部分分配' : '未分配'}}
        </view>
      </view>

      <view class="batch-list">
        <view wx:if="{{!line.candidates.length}}" class="empty-batches">当前机型暂无可分配批次</view>
        <view
          class="batch-row {{batch.selected ? 'selected' : ''}}"
          wx:for="{{line.candidates}}"
          wx:for-item="batch"
          wx:for-index="batchIndex"
          wx:key="key"
        >
          <view class="batch-main" data-line-index="{{lineIndex}}" data-batch-index="{{batchIndex}}" bindtap="toggleBatch">
            <view>
              <view class="batch-no">{{batch.batchNo}}</view>
              <view class="batch-meta">{{batch.inventoryTypeText}} · 预计入库 {{batch.eta || '-'}}</view>
              <view class="batch-meta">可选 {{batch.available}} 台</view>
            </view>
            <view class="recommend {{batch.recommended ? 'yes' : 'no'}}">{{batch.recommended ? '推荐' : '不推荐'}}</view>
          </view>

          <view wx:if="{{batch.selected}}" class="qty-row">
            <button data-line-index="{{lineIndex}}" data-batch-index="{{batchIndex}}" data-delta="-1" bindtap="changeQty">-</button>
            <input type="number" value="{{batch.quantity}}" data-line-index="{{lineIndex}}" data-batch-index="{{batchIndex}}" bindinput="onQtyInput" />
            <button data-line-index="{{lineIndex}}" data-batch-index="{{batchIndex}}" data-delta="1" bindtap="changeQty">+</button>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="card note-card">
    <view class="label">分配备注</view>
    <textarea placeholder="填写给工厂审核的备注（可选）" value="{{note}}" bindinput="onNoteInput"></textarea>
  </view>

  <view wx:if="{{!canSubmit}}" class="submit-hint">所有机型分配数量必须刚好等于需求数量后才能提交。</view>
  <button class="primary-btn submit-btn" loading="{{submitting}}" disabled="{{submitting || loading}}" bindtap="submit">提交分配并进入工厂审核</button>
</view>
