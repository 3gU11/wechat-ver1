.history-list {
  display: flex;
  flex-direction: column;
}

.filter-panel {
  margin: 18rpx 0;
  padding: 18rpx;
  border: 1rpx solid #d8e4f5;
  border-radius: 12rpx;
  background: #ffffff;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 64rpx;
  padding: 0 18rpx;
  border: 1rpx solid #d8e4f5;
  border-radius: 8rpx;
  font-size: 25rpx;
  box-sizing: border-box;
}

.clear-search {
  width: 92rpx;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0;
  border-radius: 8rpx;
  background: #eef4ff;
  color: #1f4f9a;
  font-size: 24rpx;
}

.order-card {
  padding: 24rpx;
}

.order-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.order-id {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 700;
  color: #14366f;
  word-break: break-all;
}

.tag.done {
  background: #e8f7ef;
  color: #087443;
}

.customer {
  margin-top: 18rpx;
  font-size: 28rpx;
  color: #172033;
}

.meta,
.time {
  margin-top: 10rpx;
  color: #66758f;
  font-size: 25rpx;
}

.line-item {
  margin-top: 10rpx;
  padding: 12rpx 14rpx;
  border-radius: 12rpx;
  background: #f7faff;
  color: #334155;
  font-size: 25rpx;
  line-height: 1.5;
}

.extra-row {
  margin-top: 10rpx;
  min-height: 44rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.extra-label {
  flex: 0 0 auto;
  color: #66758f;
  font-size: 24rpx;
}

.extra-text {
  min-width: 0;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 24rpx;
  color: #334155;
}

.extra-qty {
  flex: 0 0 auto;
  font-size: 24rpx;
  color: #66758f;
}

.review-note {
  margin-top: 10rpx;
  padding: 12rpx 14rpx;
  border-radius: 8rpx;
  background: #fef3c7;
  color: #92400e;
  font-size: 24rpx;
  line-height: 1.5;
}

.empty {
  padding: 80rpx 0;
  text-align: center;
  font-size: 26rpx;
}

.actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 18rpx;
}

.detail-btn {
  width: 190rpx;
  height: 60rpx;
  line-height: normal;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  background: #eef4ff;
  color: #1f4f9a;
  font-size: 24rpx;
  font-weight: 700;
}
