<view class="page">
  <view wx:if="{{!isLoggedIn}}" class="login-panel">
    <view class="login-title">经销商登录</view>
    <view class="login-desc">普通经销商审核通过后才能登录。演示账号可直接使用。</view>

    <view class="card form-card">
      <view class="field">
        <view class="label">手机号 / admin</view>
        <input placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" />
      </view>
      <view class="field">
        <view class="label">验证码 / 密码</view>
        <input placeholder="经销商 123456，admin admin123" password value="{{password}}" bindinput="onPasswordInput" />
      </view>
    </view>

    <button class="primary-btn login-btn" loading="{{submitting}}" bindtap="login">登录</button>
    <view wx:if="{{statusText}}" class="status-text">{{statusText}}</view>
    <button class="secondary-btn login-btn" bindtap="goRegister">申请成为经销商</button>

    <view class="demo muted">
      <view>演示经销商：13800000000 / 123456</view>
      <view>演示管理员：admin / admin123</view>
    </view>
  </view>

  <view wx:elif="{{isAdminAccount}}">
    <view class="hero">
      <view>
        <view class="hero-title">管理员</view>
        <view class="hero-subtitle">{{account.name}}，请进入经销商审核页面处理注册申请。</view>
      </view>
    </view>
    <button class="primary-btn action-btn" bindtap="goAdminReviews">进入经销商审核</button>
  </view>

  <view wx:else>
    <view class="hero">
      <view>
        <view class="hero-title">可订机型</view>
        <view class="hero-subtitle">{{account.name}}，成品和在制分开展示，按预计入库时间加入购物车。</view>
      </view>
    </view>

    <view class="section-title">公开库存</view>
    <view class="card table-card">
      <view class="table-row table-head">
        <text>机型</text>
        <text>成品</text>
        <text>在制</text>
      </view>
      <view class="table-row" wx:for="{{models}}" wx:key="model">
        <text>{{item.model}}</text>
        <text>{{item.finished}}</text>
        <text>{{item.wip}}</text>
      </view>
    </view>

    <button class="primary-btn action-btn" bindtap="goMachines">查看预计入库并加入购物车</button>
    <button class="secondary-btn action-btn" bindtap="goCart">进入购物车提交订单</button>
  </view>
</view>
