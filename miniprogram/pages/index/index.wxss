.login-panel {
  padding-top: 38rpx;
}

.login-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #14366f;
  letter-spacing: 0;
}

.login-desc {
  margin: 14rpx 0 34rpx;
  color: #66758f;
  font-size: 28rpx;
  line-height: 1.6;
}

.form-card {
  padding: 10rpx 28rpx;
}

.field {
  padding: 24rpx 0;
  border-top: 1rpx solid #e4ecf8;
}

.field:first-child {
  border-top: 0;
}

.label {
  margin-bottom: 12rpx;
  color: #1f4f9a;
  font-size: 26rpx;
  font-weight: 700;
}

input {
  height: 78rpx;
  color: #172033;
  font-size: 30rpx;
}

.login-btn {
  width: 100%;
  margin-top: 24rpx;
}

.status-text {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 12rpx;
  background: #eaf2ff;
  color: #14366f;
  font-size: 25rpx;
  line-height: 1.5;
}

.demo {
  margin-top: 36rpx;
  font-size: 24rpx;
  line-height: 1.8;
}

.hero {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 8rpx 0 24rpx;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #14366f;
}

.hero-subtitle {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #66758f;
  line-height: 1.5;
}

.action-btn {
  width: 100%;
  margin-top: 28rpx;
}

.table-card {
  overflow: hidden;
}

.table-row {
  display: flex;
  padding: 22rpx 24rpx;
  border-top: 1rpx solid #eef2f6;
  font-size: 27rpx;
}

.table-row:first-child {
  border-top: 0;
}

.table-head {
  background: #eaf2ff;
  color: #1f4f9a;
  font-size: 24rpx;
  font-weight: 700;
}


.table-row text {
  flex: 1;
}

.table-row text:first-child {
  flex: 1.3;
}
