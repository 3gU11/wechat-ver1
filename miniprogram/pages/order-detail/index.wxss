.summary-card,
.info-card,
.lines-card {
  padding: 24rpx;
}

.top-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.order-id {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 700;
  color: #14366f;
  word-break: break-all;
}

.tag.done {
  background: #e8f7ef;
  color: #087443;
}

.card-title {
  margin-bottom: 12rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #14366f;
}

.field {
  margin-top: 12rpx;
  color: #334155;
  font-size: 25rpx;
  line-height: 1.5;
}

.note {
  margin-top: 12rpx;
  padding: 12rpx 14rpx;
  border-radius: 8rpx;
  background: #fef3c7;
  color: #92400e;
  font-size: 24rpx;
  line-height: 1.5;
}

.note.pending {
  background: #fff7ed;
}

.line-item {
  margin-top: 12rpx;
  padding: 14rpx;
  border-radius: 12rpx;
  background: #f7faff;
}

.line-main {
  color: #172033;
  font-size: 26rpx;
  font-weight: 700;
}

.line-meta {
  margin-top: 8rpx;
  color: #66758f;
  font-size: 24rpx;
}

.empty {
  padding: 80rpx 0;
  text-align: center;
  font-size: 26rpx;
}
