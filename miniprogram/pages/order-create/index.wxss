.hint {
  margin-bottom: 20rpx;
  color: #66758f;
  font-size: 27rpx;
  line-height: 1.6;
}

.cart-card,
.form-card {
  padding: 8rpx 24rpx;
  margin-bottom: 20rpx;
}

.cart-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.total,
.limit,
.meta {
  color: #66758f;
  font-size: 25rpx;
}

.empty-cart {
  padding: 40rpx 0;
  color: #98a2b3;
  text-align: center;
  font-size: 26rpx;
}

.cart-row {
  display: flex;
  align-items: center;
  padding: 22rpx 0;
  border-top: 1rpx solid #e4ecf8;
}

.cart-info {
  flex: 1;
  min-width: 0;
  padding-right: 16rpx;
}

.model {
  color: #14366f;
  font-size: 30rpx;
  font-weight: 700;
  word-break: break-all;
}

.stepper {
  width: 176rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid #d8e4f5;
  border-radius: 12rpx;
  overflow: hidden;
}

.stepper button {
  width: 52rpx;
  height: 52rpx;
  line-height: 52rpx;
  padding: 0;
  border-radius: 0;
  background: #eaf2ff;
  color: #1f4f9a;
  font-size: 30rpx;
  font-weight: 700;
}

.stepper text {
  flex: 1;
  text-align: center;
  color: #172033;
  font-size: 28rpx;
}

.remove {
  width: 88rpx;
  height: 56rpx;
  line-height: 56rpx;
  margin-left: 16rpx;
  padding: 0;
  border-radius: 12rpx;
  background: #fff1f2;
  color: #be123c;
  font-size: 24rpx;
}

.field {
  padding: 22rpx 0;
  border-top: 1rpx solid #e4ecf8;
}

.field:first-child {
  border-top: 0;
}

.label {
  margin-bottom: 12rpx;
  color: #1f4f9a;
  font-size: 26rpx;
  font-weight: 700;
}

input {
  height: 78rpx;
  font-size: 30rpx;
}

.date-picker {
  height: 78rpx;
  line-height: 78rpx;
  color: #172033;
  font-size: 30rpx;
}

.date-picker.placeholder {
  color: #98a2b3;
}

textarea {
  width: 100%;
  min-height: 150rpx;
  font-size: 28rpx;
}

.submit-btn {
  width: 100%;
  margin-top: 28rpx;
}

