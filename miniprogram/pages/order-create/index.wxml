<view class="page">
  <view class="section-title">提交机型需求</view>
  <view class="hint">普通经销商只提交机型、数量和客户信息，具体批次由所属大区经理分配。</view>

  <view class="card cart-card">
    <view class="cart-head">
      <view class="card-title">购物车</view>
      <view class="total">共 {{totalQty}} 台</view>
    </view>
    <view wx:if="{{!cart.length}}" class="empty-cart">购物车为空，请先从机型页面选择机型。</view>
    <view wx:for="{{cart}}" wx:key="model" class="cart-row">
      <view class="cart-main">
        <view class="cart-info">
          <view class="model">{{item.model}}</view>
          <view class="meta">待大区经理分配具体批次</view>
        </view>
        <view class="stepper">
          <button data-index="{{index}}" data-delta="-1" bindtap="changeQty">-</button>
          <text>{{item.quantity}}</text>
          <button data-index="{{index}}" data-delta="1" bindtap="changeQty">+</button>
        </view>
        <button class="remove" data-index="{{index}}" bindtap="removeItem">移除</button>
      </view>
      <textarea class="item-remark" placeholder="该机型备注（可选）" value="{{item.remark || ''}}" data-index="{{index}}" bindinput="onItemRemarkInput"></textarea>
    </view>
  </view>

  <view class="card form-card">
    <view class="field">
      <view class="label">所属大区经理</view>
      <input value="{{regionalManagerName || '未绑定'}}" disabled />
    </view>
    <view class="field">
      <view class="label">客户名称</view>
      <input placeholder="终端客户或项目名称" data-field="customerName" bindinput="onInput" />
    </view>
    <view class="field">
      <view class="label">联系人</view>
      <input placeholder="客户联系人" data-field="contactName" bindinput="onInput" />
    </view>
    <view class="field">
      <view class="label">联系电话</view>
      <input placeholder="手机号或座机" type="number" data-field="contactPhone" bindinput="onInput" />
    </view>
    <view class="field">
      <view class="label">期望交期</view>
      <picker mode="date" value="{{form.deliveryDate}}" bindchange="onDeliveryDateChange">
        <view class="date-picker {{form.deliveryDate ? '' : 'placeholder'}}">{{form.deliveryDate || '请选择日期'}}</view>
      </picker>
    </view>
    <view class="field" style="height: 324rpx; display: block; box-sizing: border-box">
      <view class="label">备注</view>
      <textarea placeholder="配置要求、付款信息、运输要求等" data-field="remark" bindinput="onInput"></textarea>
    </view>
  </view>

  <button class="primary-btn submit-btn" loading="{{submitting}}" bindtap="submit">提交订单</button>
</view>
