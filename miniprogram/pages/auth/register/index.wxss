.hint {
  margin-bottom: 20rpx;
  color: #66758f;
  font-size: 27rpx;
  line-height: 1.6;
}

.form-card {
  padding: 10rpx 28rpx;
}

.field {
  padding: 22rpx 0;
  border-top: 1rpx solid #e4ecf8;
}

.field:first-child {
  border-top: 0;
}

.label {
  margin-bottom: 12rpx;
  color: #1f4f9a;
  font-size: 26rpx;
  font-weight: 700;
}

input {
  height: 78rpx;
  font-size: 30rpx;
}

.picker-value {
  min-height: 72rpx;
  line-height: 72rpx;
  color: #172033;
  font-size: 30rpx;
}

textarea {
  width: 100%;
  min-height: 150rpx;
  font-size: 28rpx;
}

.submit-btn {
  width: 100%;
  margin-top: 28rpx;
}

.agreement-block {
  margin-top: 24rpx;
  padding: 24rpx;
  border: 1rpx solid #d8e4f5;
  border-radius: 12rpx;
  background: #ffffff;
}

.agreement-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.agreement-links {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
  padding-left: 52rpx;
}

.agreement-text {
  color: #526173;
  font-size: 26rpx;
  line-height: 1.5;
}

.agreement-link {
  color: #1f4f9a;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.5;
}

.agreement-note {
  margin-top: 14rpx;
  color: #66758f;
  font-size: 24rpx;
  line-height: 1.5;
}

