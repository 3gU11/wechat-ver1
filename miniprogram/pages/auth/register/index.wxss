.hint {
  margin-bottom: 20rpx;
  color: #66758f;
  font-size: 27rpx;
  line-height: 1.6;
}

.form-card {
  padding: 10rpx 28rpx;
}

.field {
  padding: 22rpx 0;
  border-top: 1rpx solid #e4ecf8;
}

.field:first-child {
  border-top: 0;
}

.label {
  margin-bottom: 12rpx;
  color: #1f4f9a;
  font-size: 26rpx;
  font-weight: 700;
}

input {
  height: 78rpx;
  font-size: 30rpx;
}

.picker-value {
  min-height: 72rpx;
  line-height: 72rpx;
  color: #172033;
  font-size: 30rpx;
}

textarea {
  width: 100%;
  min-height: 150rpx;
  font-size: 28rpx;
}

.submit-btn {
  width: 100%;
  margin-top: 28rpx;
}

