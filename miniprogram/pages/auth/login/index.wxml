<view class="page login-page">
  <view class="brand-strip">
    <image class="brand-logo" src="/images/rj-logo.png" mode="aspectFit" />
    <view>
      <view class="app-title">瑞钧智科智能订单管理</view>
      <view class="brand-name">经销商门户</view>
      <view class="brand-subtitle">登录</view>
    </view>
  </view>
  <view class="login-title">经销商登录</view>
  <view class="login-desc">普通经销商和大区经理审核通过后，使用手机号和登录密码进入小程序。</view>

  <view class="card form-card">
    <view class="field">
      <view class="label">手机号</view>
      <input placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" />
    </view>
    <view class="field">
      <view class="label">登录密码</view>
      <input placeholder="请输入登录密码" password value="{{password}}" bindinput="onPasswordInput" />
    </view>
  </view>

  <button class="primary-btn login-btn" loading="{{submitting}}" bindtap="login">登录</button>
  <view wx:if="{{statusText}}" class="status-text">{{statusText}}</view>
  <button class="secondary-btn register-btn" bindtap="goRegister">申请成为经销商</button>
</view>
