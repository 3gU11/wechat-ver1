<view class="page login-page">
  <view class="brand-strip">
    <image class="brand-logo" src="/images/rj-logo.png" mode="aspectFit" />
    <view>
      <view class="app-title">瑞钧智科智能订单管理</view>
      <view class="brand-subtitle">微信账号登录</view>
    </view>
  </view>

  <view class="login-title">经销商门户</view>
  <view class="login-desc">使用当前微信账号登录。首次使用会进入注册资料填写，管理员审核通过后即可进入小程序。</view>

  <button class="primary-btn login-btn" loading="{{submitting}}" bindtap="wechatLogin">微信登录 / 注册</button>
  <view class="login-agreement">
    <text>登录或注册即表示您已阅读并同意</text>
    <text class="agreement-link" data-type="terms" bindtap="openAgreement">《用户服务协议》</text>
    <text>和</text>
    <text class="agreement-link" data-type="privacy" bindtap="openAgreement">《隐私政策》</text>
  </view>
  <view wx:if="{{statusText}}" class="status-text">{{statusText}}</view>

  <view class="card form-card">
    <view class="field">
      <view class="label">管理员账号</view>
      <input placeholder="请输入管理员账号" value="{{adminPhone}}" bindinput="onAdminPhoneInput" />
    </view>
    <view class="field">
      <view class="label">管理员密码</view>
      <input placeholder="请输入管理员密码" password value="{{adminPassword}}" bindinput="onAdminPasswordInput" />
    </view>
  </view>

  <button class="secondary-btn register-btn" loading="{{adminSubmitting}}" bindtap="adminLogin">管理员登录</button>
</view>
