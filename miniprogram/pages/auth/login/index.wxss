.login-page {
  padding-top: 44rpx;
}

.login-page .brand-strip {
  flex-direction: column;
  justify-content: center;
  gap: 14rpx;
  margin-bottom: 34rpx;
  text-align: center;
}

.login-page .brand-logo {
  width: 50vw;
  height: 17vw;
  max-width: 380rpx;
  max-height: 128rpx;
}

.app-title {
  margin-top: 6rpx;
  color: #14366f;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.3;
}

.login-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #14366f;
  text-align: center;
}

.login-desc {
  margin: 14rpx 0 34rpx;
  color: #66758f;
  font-size: 28rpx;
  line-height: 1.6;
  text-align: center;
}

.form-card {
  padding: 10rpx 28rpx;
}

.field {
  padding: 24rpx 0;
  border-top: 1rpx solid #e4ecf8;
}

.field:first-child {
  border-top: 0;
}

.label {
  margin-bottom: 12rpx;
  color: #1f4f9a;
  font-size: 26rpx;
  font-weight: 700;
}

input {
  height: 78rpx;
  font-size: 30rpx;
}

.login-btn,
.register-btn {
  width: 100%;
  margin-top: 24rpx;
}

.status-text {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 12rpx;
  background: #eaf2ff;
  color: #14366f;
  font-size: 25rpx;
  line-height: 1.5;
}

.demo {
  margin-top: 36rpx;
  font-size: 24rpx;
  line-height: 1.8;
}

