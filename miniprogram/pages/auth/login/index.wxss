.login-page {
  padding-top: 70rpx;
}

.login-title {
  font-size: 46rpx;
  font-weight: 700;
  color: #111827;
}

.login-desc {
  margin: 14rpx 0 34rpx;
  color: #667085;
  font-size: 26rpx;
  line-height: 1.6;
}

.form-card {
  padding: 8rpx 24rpx;
}

.field {
  padding: 24rpx 0;
  border-top: 1rpx solid #eef2f6;
}

.field:first-child {
  border-top: 0;
}

.label {
  margin-bottom: 12rpx;
  color: #344054;
  font-size: 25rpx;
  font-weight: 600;
}

input {
  height: 72rpx;
  font-size: 28rpx;
}

.login-btn,
.register-btn {
  width: 100%;
  margin-top: 24rpx;
}

.status-text {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 8rpx;
  background: #f2f4f7;
  color: #344054;
  font-size: 25rpx;
  line-height: 1.5;
}

.demo {
  margin-top: 36rpx;
  font-size: 24rpx;
  line-height: 1.8;
}

