page {
  min-height: 100%;
  background: #f3f7ff;
  color: #172033;
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "SF Pro Text", "PingFang SC", "Helvetica Neue", "Microsoft YaHei", sans-serif;
}

.page {
  min-height: 100%;
  box-sizing: border-box;
  padding: 28rpx;
}

.section-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #14366f;
  margin: 12rpx 0 22rpx;
  letter-spacing: 0;
}

.muted {
  color: #66758f;
}

.card {
  background: #ffffff;
  border: 1rpx solid #e4ecf8;
  border-radius: 12rpx;
  box-sizing: border-box;
  box-shadow: 0 8rpx 28rpx rgba(31, 79, 154, 0.08);
}

.primary-btn {
  height: 88rpx;
  line-height: normal;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  padding: 0 28rpx;
  border-radius: 12rpx;
  background: #1f4f9a;
  color: #ffffff;
  font-size: 31rpx;
  font-weight: 700;
}

.secondary-btn {
  height: 80rpx;
  line-height: normal;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  padding: 0 28rpx;
  border-radius: 12rpx;
  background: #fff3df;
  color: #b55c00;
  font-size: 29rpx;
  font-weight: 700;
}

.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #eaf2ff;
  color: #1f4f9a;
  font-size: 24rpx;
  font-weight: 600;
}

.tag.warn {
  background: #fff3df;
  color: #b55c00;
}

.tag.gray {
  background: #f1f5fb;
  color: #526173;
}

.brand-strip {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 30rpx;
}

.brand-logo {
  width: 184rpx;
  height: 62rpx;
}

.brand-name {
  color: #14366f;
  font-size: 30rpx;
  font-weight: 800;
}

.brand-subtitle {
  margin-top: 4rpx;
  color: #f59e0b;
  font-size: 22rpx;
  font-weight: 700;
}

