page {
  min-height: 100%;
  background: #f5f7fa;
  color: #1f2937;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page {
  min-height: 100%;
  box-sizing: border-box;
  padding: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #111827;
  margin: 8rpx 0 20rpx;
}

.muted {
  color: #667085;
}

.card {
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.primary-btn {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 8rpx;
  background: #0f766e;
  color: #ffffff;
  font-size: 30rpx;
}

.secondary-btn {
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 8rpx;
  background: #eef6f5;
  color: #0f766e;
  font-size: 28rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 14rpx;
  border-radius: 6rpx;
  background: #ecfdf3;
  color: #067647;
  font-size: 24rpx;
}

.tag.warn {
  background: #fff7ed;
  color: #b45309;
}

.tag.gray {
  background: #f2f4f7;
  color: #475467;
}

